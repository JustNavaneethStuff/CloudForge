# Application environment variables (local development only).
# In AWS, secrets are injected via ECS task definition from Secrets Manager.

APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# Database (local dev with docker-compose or direct connection)
DATABASE_URL=postgresql://cloudforge:cloudforge@localhost:5432/cloudforge

# Redis (local dev)
REDIS_URL=redis://localhost:6379/0
